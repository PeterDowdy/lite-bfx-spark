<?xml version="1.0"?>
<!-- Checkstyle configuration: enforces Google Java Style with project-specific overrides. -->
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle configuration for lite-bfx-spark.
  Applied to production Java source only (test sources excluded).
  Run manually: mvn checkstyle:check
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- File-level checks (no TreeWalker needed) -->

  <!-- No tab characters anywhere in source files -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>

  <!-- No trailing whitespace -->
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="minimum" value="0"/>
    <property name="maximum" value="0"/>
    <property name="message" value="Line has trailing whitespace."/>
  </module>

  <!-- Max line length: 130. Packages, imports, and URLs are exempt. -->
  <module name="LineLength">
    <property name="max" value="130"/>
    <property name="ignorePattern" value="^package\s|^import\s|https?://|ftp://"/>
  </module>

  <!-- Tree-walker checks (AST-based, per-file) -->
  <module name="TreeWalker">

    <!-- Imports -->
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>

    <!-- Naming conventions -->

    <!-- Class / interface / enum / record names: UpperCamelCase -->
    <module name="TypeName"/>

    <!-- Package names: all lowercase, dotted segments -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>

    <!-- Method names: lowerCamelCase -->
    <module name="MethodName"/>

    <!-- Instance fields: lowerCamelCase -->
    <module name="MemberName"/>

    <!-- Static (non-final) fields: lowerCamelCase -->
    <module name="StaticVariableName"/>

    <!-- Local variables and catch parameters: lowerCamelCase, single letters allowed -->
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>

    <!-- Method parameters: lowerCamelCase -->
    <module name="ParameterName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>

    <!--
      Static final constants: UPPER_SNAKE_CASE.
      Exception: SLF4J loggers are universally named 'log' by convention
      (private static final Logger log = ...) and are excluded from the
      UPPER_SNAKE_CASE requirement.
    -->
    <module name="ConstantName">
      <property name="format" value="^log$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
    </module>

    <!-- Modifiers must be in JLS order: public protected private abstract static final ... -->
    <module name="ModifierOrder"/>

    <!-- Code style -->

    <!-- Use T[] not T x[] -->
    <module name="ArrayTypeStyle"/>

    <!-- Long literals must use uppercase L, not lowercase l -->
    <module name="UpperEll"/>

    <!-- Empty catch blocks: only allowed when variable is named ignore/ignored/expected -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="ignore|ignored|expected"/>
    </module>

  </module>
</module>
